# ─── Local Development (SQLite) ─────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth (next-auth v5 uses AUTH_SECRET) ────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="your-32-char-secret-here"
NEXTAUTH_SECRET="your-32-char-secret-here"   # keep both for compatibility
NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Production ───────────────────────────────────────
# DATABASE_URL="postgres://..."   (set to POSTGRES_PRISMA_URL from Vercel Storage)
# AUTH_SECRET="..."               (same secret, set in Vercel env vars)
# NEXTAUTH_URL="https://whostheimpostor.vercel.app"
